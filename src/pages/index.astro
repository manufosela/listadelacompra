---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="MyHomeCart">
  <main class="redirect-screen">
    <div class="redirect-logo" aria-hidden="true">
      <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <linearGradient id="landingLogoGrad" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" style="stop-color:#e8896c"/>
            <stop offset="100%" style="stop-color:#c9624a"/>
          </linearGradient>
        </defs>
        <rect width="64" height="64" rx="16" fill="url(#landingLogoGrad)"/>
        <g transform="translate(8, 8)">
          <path d="M4 10 L10 10 L13 18" stroke="#ffffff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
          <path d="M24 12 L38 22 L10 22 Z" fill="#f0c87a"/>
          <path d="M24 8 L42 24 L40 24 L24 11 L8 24 L6 24 Z" fill="#ffffff"/>
          <path d="M10 24 L10 38 L38 38 L38 24 Z" fill="#ffffff"/>
          <rect x="20" y="28" width="8" height="10" rx="1" fill="#e07b5c"/>
          <circle cx="26" cy="33" r="1" fill="#c9624a"/>
          <rect x="12" y="26" width="6" height="6" rx="1" fill="#f2a890"/>
          <rect x="30" y="26" width="6" height="6" rx="1" fill="#f2a890"/>
          <circle cx="16" cy="42" r="4" fill="#ffffff"/>
          <circle cx="32" cy="42" r="4" fill="#ffffff"/>
          <circle cx="16" cy="42" r="2" fill="#e07b5c"/>
          <circle cx="32" cy="42" r="2" fill="#e07b5c"/>
        </g>
      </svg>
    </div>
    <p class="redirect-text">Cargando…</p>
    <noscript>
      <a href="/login" class="btn btn-primary">Iniciar sesión</a>
    </noscript>
  </main>
</BaseLayout>

<script type="module">
  import { onAuthStateChanged } from '/js/auth.js';
  // App privada: la raíz lleva directamente al login, o a la app si ya hay sesión.
  onAuthStateChanged((user) => {
    window.location.replace(user ? '/app' : '/login');
  });
</script>

<style>
  .redirect-screen {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
    text-align: center;
    padding: var(--space-xl);
  }

  .redirect-logo {
    width: 88px;
    height: 88px;
    animation: pulse 1.4s ease-in-out infinite;
  }

  .redirect-logo svg {
    width: 100%;
    height: 100%;
    filter: drop-shadow(0 10px 30px rgba(224, 123, 92, 0.25));
  }

  .redirect-text {
    color: var(--color-text-secondary);
    font-size: var(--font-size-sm);
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.6; transform: scale(0.98); }
    50% { opacity: 1; transform: scale(1); }
  }

  @media (prefers-reduced-motion: reduce) {
    .redirect-logo { animation: none; }
  }
</style>
