rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ==================== HELPERS ====================

    function isAuthenticated() {
      return request.auth != null;
    }

    function userId() {
      return request.auth.uid;
    }

    // Verifica si el archivo es una imagen válida
    function isValidImage() {
      return request.resource.contentType.matches('image/.*')
        && request.resource.size < 10 * 1024 * 1024; // Max 10MB
    }

    // Verifica si el usuario es miembro del grupo consultando Firestore.
    // Storage rules pueden leer Firestore con firestore.get()/firestore.exists().
    function isGroupMember(groupId) {
      return isAuthenticated()
        && firestore.exists(/databases/(default)/documents/groups/$(groupId))
        && userId() in firestore.get(/databases/(default)/documents/groups/$(groupId)).data.members;
    }

    // ==================== USER AVATARS ====================

    match /users/{userId}/avatar/{fileName} {
      // Cualquiera puede ver avatares
      allow read: if isAuthenticated();

      // Solo el propio usuario puede subir su avatar
      allow write: if isAuthenticated()
        && userId == userId()
        && isValidImage();
    }

    // ==================== LIST ICONS ====================

    match /list-icons/{listId} {
      // Lectura pública (las imágenes se cargan sin token)
      allow read: if true;

      // NOTA: la ruta no incluye groupId, por lo que aquí no se puede validar
      // pertenencia a grupo sin cambiar la estructura de almacenamiento a
      // "list-icons/{groupId}/{listId}". Pendiente en la fase de arquitectura.
      // Riesgo actual: un usuario autorizado podría sobrescribir el icono de otra
      // lista (defacement de bajo impacto en un despliegue privado).
      allow write: if isAuthenticated() && isValidImage();
    }

    // ==================== GROUP ICONS ====================

    match /group-icons/{fileName} {
      // Lectura pública (los iconos se cargan sin token)
      allow read: if true;

      // Solo miembros del grupo pueden subir/actualizar su icono, y solo imágenes.
      // El nombre de fichero es "{groupId}.{ext}"; extraemos el groupId antes del punto.
      allow write: if isValidImage()
        && isGroupMember(fileName.split('\\.')[0]);
    }

    // ==================== PRODUCT IMAGES ====================

    match /product-images/{groupId}/{fileName} {
      // Lectura pública (las imágenes se cargan sin token)
      allow read: if true;

      // Solo miembros del grupo pueden subir/actualizar imágenes de productos
      allow write: if isValidImage() && isGroupMember(groupId);
    }

    // ==================== GROUP TICKETS ====================

    match /groups/{groupId}/tickets/{ticketId} {
      // Solo miembros del grupo pueden ver los tickets (recibos con datos financieros)
      allow read: if isGroupMember(groupId);

      // Solo miembros del grupo pueden subir tickets, y solo imágenes
      allow create: if isValidImage() && isGroupMember(groupId);

      // No se permite modificar tickets existentes
      allow update: if false;

      // Solo miembros del grupo pueden eliminar
      allow delete: if isGroupMember(groupId);
    }
  }
}
